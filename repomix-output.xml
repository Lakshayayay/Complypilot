                    const deadlinesOnDate = getDeadlinesForDate(date);
                    if (deadlinesOnDate.length === 0) return false;
                    const days = getDaysUntilDeadline(deadlinesOnDate[0].deadline);
                    return days > 3 && days <= 14;
                  },
                  onTrack: (date) => {
                    const deadlinesOnDate = getDeadlinesForDate(date);
